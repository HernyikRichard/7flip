rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email;
      allow delete: if false;

      // Értesítések — más auth user is írhat (pl. meghívó elutasítása)
      match /notifications/{notifId} {
        allow read, update: if isOwner(userId);
        allow create: if isSignedIn();
      }
    }

    // ── Friend Requests ───────────────────────────────────────────────────────
    match /friendRequests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid == request.auth.uid
      );
      allow create: if isSignedIn() &&
        request.resource.data.fromUid == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if isSignedIn() && (
        // Fogadó elfogadja/elutasítja
        resource.data.toUid == request.auth.uid ||
        // Küldő visszavonja (státusz pending marad, de törölheti)
        resource.data.fromUid == request.auth.uid
      );
      allow delete: if isSignedIn() && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid == request.auth.uid
      );
    }

    // ── Friendships ───────────────────────────────────────────────────────────
    match /friendships/{friendshipId} {
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.userIds;
      // Kliens hozza létre elfogadáskor — mindkét uid bent kell legyen
      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.userIds;
      allow update: if false;
      allow delete: if isSignedIn() &&
        request.auth.uid in resource.data.userIds;
    }

    // ── User Status (aktív játék státusz — bármely bejelentkezett user olvashatja/írhatja) ──
    match /userStatus/{uid} {
      allow read: if isSignedIn();
      // Bármely bejelentkezett user írhat (game service frissíti a többi játékos státuszát is)
      allow write: if isSignedIn();
    }

    // ── Games ─────────────────────────────────────────────────────────────────
    match /games/{gameId} {
      // Olvasás: játékos, QR lobby meghívott, VAGY spectateEnabled néző.
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.playerUids ||
        (resource.data.inviteEnabled == true &&
         resource.data.status == 'waiting_for_players') ||
        resource.data.spectateEnabled == true
      );
      allow create: if isSignedIn() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.auth.uid in request.resource.data.playerUids;
      // Írás: csak játékosok és QR lobby csatlakozók.
      // Spectator soha nem írhat game state-et.
      allow update: if isSignedIn() && (
        // Meglévő játékos bármit frissíthet
        request.auth.uid in resource.data.playerUids
        // Csatlakozás invite-tal: csak a join művelet mezői engedélyezettek
        || (resource.data.inviteEnabled == true
            && resource.data.status == 'waiting_for_players'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players', 'playerUids', 'updatedAt']))
      );
      allow delete: if false;

      match /rounds/{roundId} {
        // Spectator olvashatja a kör állapotát ha spectateEnabled.
        allow read: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.playerUids ||
          get(/databases/$(database)/documents/games/$(gameId)).data.spectateEnabled == true
        );
        // Csak játékosok írhatnak round state-et.
        allow create, update: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.playerUids;
        allow delete: if false;
      }

      match /presence/{uid} {
        // Spectator is olvashatja a jelenléteket ha spectateEnabled.
        allow read: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.playerUids ||
          get(/databases/$(database)/documents/games/$(gameId)).data.spectateEnabled == true
        );
        // Mindenki csak a saját presence doksiját írhatja.
        allow create, update: if isSignedIn() && request.auth.uid == uid;
        allow delete: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // ── Scan Results ──────────────────────────────────────────────────────────
    match /scanResults/{scanId} {
      allow read: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
